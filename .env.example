# ResFes 2026 Environment Configuration
# ========================================
# Copy this file to .env and fill in your actual values

# Groq API Configuration
# Get your free API key from: https://console.groq.com
# No credit card required
GROQ_API_KEY=your_groq_api_key_here

# Knowledge Base Server Configuration
# Set this to the URL of the KB Server running on your phone
# Example: http://192.168.1.100:5001
# Leave empty if running in local mode
KB_SERVER_URL=

# KB Mode: 'auto' (default), 'local', or 'remote'
# - auto: Use remote KB if KB_SERVER_URL is set, otherwise local
# - local: Only use local knowledge base (no phone connection needed)
# - remote: Only use remote KB server (must set KB_SERVER_URL)
RESFES_KB_MODE=auto

# Local Data Directory
# Where to store uploaded documents and knowledge base
# Default: ./app_data (relative to project root)
# Set to absolute path if needed
RESFES_DATA_DIR=./app_data
